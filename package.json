{
  "name": "pos-server",
  "version": "1.0.0",
  "packageManager": "yarn@1.22.22",
  "description": "POS GraphQL Server with Apollo and AWS",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "params": "node --import tsx src/scripts/params.ts",
    "seed:mvp": "yarn build && node dist/scripts/seed-mvp.js",
    "bundle:lambda": "yarn build && esbuild src/lambda.ts --bundle --platform=node --target=node24 --format=cjs --outfile=lambda-package/dist/lambda.js --sourcemap --sources-content=false",
    "test": "yarn build && node dist/scripts/seed-mvp.js --validate-only && node test/seed-catalog.js && node test/auth.js && node test/authorization.js && node test/tenant-repository.js && node test/pos-repository.js && node test/lambda-smoke.js",
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "keywords": [
    "pos",
    "graphql",
    "apollo",
    "aws"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/aws-lambda": "^4.1.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1090.0",
    "@aws-sdk/client-dynamodb": "^3.1089.0",
    "@aws-sdk/lib-dynamodb": "^3.1089.0",
    "aws-jwt-verify": "^5.1.1",
    "dotenv": "^17.4.2",
    "graphql": "^16.11.0"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.1090.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
