    "@aws-sdk/client-dynamodb": "^3.1089.0",
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/lib-dynamodb": "^3.1089.0",
    "aws-jwt-verify": "^5.1.1",
    "dotenv": "^16.3.1",
    "graphql": "^16.8.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
