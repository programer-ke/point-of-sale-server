{
  "name": "pos-server",
  "version": "1.0.0",
  "packageManager": "yarn@1.22.22",
  "description": "POS GraphQL Server with Apollo and AWS",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
